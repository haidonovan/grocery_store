PORT=4000
JWT_SECRET=replace_with_long_random_value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/grocery_store?sslmode=require
SEED_ON_STARTUP=false

# Comma-separated allowed origins for production (localhost allowed in dev)
CORS_ORIGIN=https://flutter-grocery.onrender.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=grocery-products

PAYWAY_MERCHANT_ID=your_payway_merchant_id
PAYWAY_PUBLIC_KEY=your_payway_public_key
PAYWAY_SANDBOX=true
# Use a public HTTPS URL that ABA can reach and whitelist it in PayWay sandbox.
SERVER_PUBLIC_URL=https://your-domain.example.com
PAYWAY_CALLBACK_URL=https://your-domain.example.com/api/payway/pushback
