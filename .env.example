PORT=4000
JWT_SECRET=replace_with_long_random_value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/grocery_store?sslmode=require
SEED_ON_STARTUP=false

# Comma-separated allowed origins for production (localhost allowed in dev)
CORS_ORIGIN=https://flutter-grocery.onrender.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=grocery-products
