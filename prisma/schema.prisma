// Prisma schema for Neon Postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  client
  admin
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled
}

enum CouponType {
  percent
  amount
}

enum CouponAudience {
  all
  user
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         UserRole @default(client)
  createdAt    DateTime @default(now())
  orders       Order[]
  ratings      ProductRating[]
  favorites    Favorite[]
  supportMessages SupportMessage[]
}

model Product {
  id          String   @id
  name        String
  category    String
  description String
  price       Float
  discountPercent Float @default(0)
  discountStart DateTime?
  discountEnd   DateTime?
  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)
  imageUrl    String
  stock       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderLines  OrderLine[]
  restocks    Restock[]
  ratings     ProductRating[]
  favorites   Favorite[]
}

model Order {
  id              String       @id
  customerId      Int
  shippingAddress String
  paymentMethod   String
  total           Float
  status          OrderStatus  @default(pending)
  createdAt       DateTime     @default(now())
  trackingNumber  String?
  trackingCarrier String?
  trackingStatus  String?
  trackingUpdatedAt DateTime?
  couponCode      String?
  couponType      CouponType?
  couponValue     Float?
  couponDiscount  Float?
  customer        User         @relation(fields: [customerId], references: [id])
  lines           OrderLine[]
}

model OrderLine {
  id          Int     @id @default(autoincrement())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  discountPercent Float @default(0)
  order       Order   @relation(fields: [orderId], references: [id])
  product     Product @relation(fields: [productId], references: [id])
}

model Restock {
  id            Int      @id @default(autoincrement())
  productId     String
  quantityAdded Int
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id])
}

model ProductRating {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId String
  rating    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model SupportMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  isResolved Boolean @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Coupon {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  type      CouponType
  value     Float
  isActive  Boolean    @default(true)
  audience  CouponAudience @default(all)
  description String?
  startsAt  DateTime?
  endsAt    DateTime?
  userEmail String?
  createdAt DateTime   @default(now())
}
